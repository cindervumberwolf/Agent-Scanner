# Agent Scanner — LLM Configuration
# Copy this file to .env and fill in your values.

# LLM mode: mock | real  (can also override via --llm CLI flag)
# LLM_MODE=mock

# Provider type (currently only openai-compatible is supported)
LLM_PROVIDER=openai-compatible

# API credentials (required when LLM_MODE=real or --llm real)
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# Debug: set to 1 to see LLM request/response logs
# DEBUG_LLM=0
